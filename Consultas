SELECT 
    c.nombre AS Cliente, 
    v.modelo AS Vehiculo, 
    con.cuota_mensual AS Cuota,
    con.fecha_fin AS 'Vencimiento Contrato'
FROM CLIENTES c
JOIN CONTRATOS con ON c.id_cliente = con.fk_cliente
JOIN VEHICULOS v ON con.fk_vehiculo = v.bastidor;

