SELECT 
    fk_contrato AS Numero_Contrato, 
    SUM(importe) AS Total_Pagado_Hasta_Hoy,
    COUNT(id_pago) AS Numero_de_Mensualidades
FROM PAGOS
GROUP BY fk_contrato;
